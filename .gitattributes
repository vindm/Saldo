# Saldo line-ending normalization.
# Goal: the repo stores text as LF on every platform, so a Windows checkout
# no longer shows hundreds of phantom CRLF-only "modified" files.
#
# Default: treat everything as text, auto-detect, and store/check out as LF.
* text=auto eol=lf

# --- Source / data / docs: explicit LF (belt and suspenders) ---
*.py    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.jsonl text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.txt   text eol=lf
*.svg   text eol=lf
*.sh    text eol=lf
LICENSE text eol=lf

# --- Windows scripts: must stay CRLF on checkout ---
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# --- Binaries: never touch ---
*.png   binary
*.gif   binary
*.jpg   binary
*.jpeg  binary
*.pdf   binary
*.ico   binary
*.woff  binary
*.woff2 binary
